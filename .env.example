NEXT_PUBLIC_SITE_URL=https://david-portfolio97.netlify.app
NEXT_PUBLIC_SANITY_PROJECT_ID=9udx7y4i

# Contact form — server-side only (never use NEXT_PUBLIC_ for SMTP credentials)
CONTACT_EMAIL_TO=huy.le1297@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=huy.le1297@gmail.com
SMTP_PASS=
# Optional custom From header (defaults to SMTP_USER)
# SMTP_FROM="Portfolio Contact" <huy.le1297@gmail.com>

# Gmail setup:
# 1. Enable 2-Step Verification on your Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Paste the 16-character app password into SMTP_PASS (no spaces)

# Optional: legacy Sanity read token (not required for contact email)
# NEXT_PUBLIC_SANITY_TOKEN=

# Server-side only — Editor token for upload-cv script (never NEXT_PUBLIC_)
# Create at: https://www.sanity.io/manage/project/9udx7y4i/api#tokens
# SANITY_API_WRITE_TOKEN=

# Visitor reviews: set to false to require manual approval in Sanity Studio
# AUTO_APPROVE_TESTIMONIALS=true

# Portfolio AI assistant — Google Gemini (free tier, server-side only)
# Get key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...
# Optional model override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Rate limiting for /api/chat (recommended for Netlify/serverless production)
# Free tier: https://upstash.com — create a Redis database, then paste REST credentials
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
